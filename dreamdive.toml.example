[defaults]
workspace = ".dreamdive"
session_id = "main"
debug = false
debug_dir = ""

[ingest]
source = "resources/dragonraja1_demo.txt"
rerun_structural_scan = false
rerun_chapters = false
rerun_meta_layer = false
rerun_entities = false
max_workers = 4
section_max_workers = 4

[init]
source = "resources/dragonraja1_demo.txt"
chapter_id = "001"
tick_label = "snapshot"
timeline_index = 0
overwrite = false

[run]
ticks = 10
overwrite = true

[background]
max_jobs = 20
max_workers = 4

[branch]
overwrite = false

[profiles.debug]
debug = true
debug_dir = "/tmp/dreamdive-debug"

[profiles.main]
session_id = "main"

[profiles.main.run]
ticks = 50
