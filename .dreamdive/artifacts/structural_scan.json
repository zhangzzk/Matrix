      "\u67d0\u4e9b\u9057\u8ff9\uff08\u5982\u9752\u94dc\u57ce\uff09\u5177\u6709\u81ea\u52a8\u9632\u5fa1\u673a\u5236\uff0c\u4e00\u65e6\u89e6\u53d1\u4f1a\u6539\u53d8\u5185\u90e8\u7ed3\u6784\u3002",
      "\u9ad8\u7eaf\u5ea6\u9f99\u65cf\u8840\u6db2\u53ef\u4f5c\u4e3a\u5f00\u542f\u53e4\u8001\u673a\u5173\u7684\u94a5\u5319\u3002"
    ],
    "setting": "\u73b0\u4ee3\u90fd\u5e02\u80cc\u666f\u4e0b\u9690\u85cf\u7684\u9f99\u65cf\u6218\u4e89\u4e16\u754c\uff0c\u4eba\u7c7b\u4e2d\u7684\u6df7\u8840\u79cd\u79d8\u5bc6\u7ec4\u5efa\u5b66\u9662\u5bf9\u6297\u5373\u5c06\u82cf\u9192\u7684\u9f99\u738b\u3002",
